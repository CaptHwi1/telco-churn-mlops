# Project
PROJECT_NAME=telco_churn
ENVIRONMENT=dev
DEBUG=true

# Paths
ARTIFACTS_PATH=artifacts
DATA_RAW_PATH=data/raw

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=telco_churn_baseline_tuning
MODEL_REGISTRY_NAME=telco_churn_model_tuned

# Model
RANDOM_STATE=42
TEST_SIZE=0.2
CV_FOLDS=5

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Logging
LOG_LEVEL=INFO

# Huawei Cloud (optional, for deployment)
HUAWEI_REGION=ap-southeast-1
HUAWEI_PROJECT_ID=telco-churn
SWR_REGISTRY=swr.ap-southeast-1.myhuaweicloud.com